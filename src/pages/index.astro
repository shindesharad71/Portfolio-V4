---
// Component Imports
import MainHead from '../components/MainHead.astro';
import Header from '../components/Header.astro';
import Intro from '../components/Intro.astro';
import Skills from '../components/Skills.astro';
import Work from '../components/Work.astro';
import Journey from '../components/Journey.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
// Global styles
import '../styles/global.scss';
---
<html lang="en">
  <head>
    <MainHead />
  </head>
  <body>
    <Cursor />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <Intro />
      <Skills />
      <Work />
      <Journey />
      <Footer />
    </main>

    <script>
      import Lenis from 'lenis';

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let lenis: InstanceType<typeof Lenis> | null = null;

      if (!prefersReducedMotion) {
        lenis = new Lenis({
          lerp: 0.1,
          smoothWheel: true,
        });

        function raf(time: number) {
          lenis?.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      (window as any).__lenis = lenis;
    </script>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        const lenis = (window as any).__lenis;
        if (lenis) {
          lenis.on('scroll', ScrollTrigger.update);
          gsap.ticker.add((time) => lenis.raf(time * 1000));
          gsap.ticker.lagSmoothing(0);
        }

        gsap.utils.toArray<HTMLElement>('[data-reveal="heading"]').forEach((el) => {
          gsap.from(el, {
            clipPath: 'inset(100% 0 0 0)',
            y: 20,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 80%', once: true },
          });
        });

        gsap.utils.toArray<HTMLElement>('[data-reveal="text"]').forEach((el) => {
          gsap.from(el, {
            opacity: 0,
            y: 30,
            duration: 0.7,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 75%', once: true },
          });
        });

        gsap.utils.toArray<HTMLElement>('[data-reveal="cards"]').forEach((container) => {
          const cards = container.children;
          gsap.from(cards, {
            scale: 0.95,
            opacity: 0,
            duration: 0.6,
            ease: 'power3.out',
            stagger: 0.08,
            scrollTrigger: { trigger: container, start: 'top 65%', once: true },
          });
        });

        gsap.utils.toArray<HTMLElement>('[data-reveal="fade"]').forEach((el) => {
          gsap.from(el, {
            opacity: 0,
            y: 20,
            duration: 0.6,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 80%', once: true },
          });
        });
      } else {
        document.querySelectorAll('[data-reveal]').forEach((el) => {
          (el as HTMLElement).style.opacity = '1';
          (el as HTMLElement).style.transform = 'none';
          (el as HTMLElement).style.clipPath = 'none';
        });
      }
    </script>
  </body>
</html>
<style lang="scss">
  main {
    padding-top: calc(var(--header-height) + var(--space-10));
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding-left: var(--space-6);
    padding-right: var(--space-6);

    @media (max-width: 768px) {
      padding-top: calc(var(--header-height) + var(--space-8));
      padding-left: var(--space-5);
      padding-right: var(--space-5);
    }
  }
</style>
