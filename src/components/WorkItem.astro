---
const { item } = Astro.props;
---
<article class="work-card" data-reveal>
    <div class="work-card-image">
        <img src={item.image} alt={item.title} loading="lazy" decoding="async">
    </div>
    <div class="work-card-content">
        <h3 class="work-card-title">{item.title}</h3>
        <p class="work-card-desc">{item.description}</p>
        {item.tech && item.tech.length > 0 &&
            <div class="work-card-tags">
                {item.tech.map(tech => (
                    <span class="tag">{tech}</span>
                ))}
            </div>
        }
        {item.link &&
            <a href={item.link} target="_blank" rel="noopener noreferrer" class="work-card-link">
                View Project
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
        }
        {item.info && <p class="work-card-info">{item.info}</p>}
    </div>
</article>
<style lang="scss">
  .work-card {
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);

    &:hover {
      border-color: var(--color-border-hover);
      box-shadow: var(--shadow-lg);

      .work-card-image img {
        transform: scale(1.03);
      }
    }
  }

  .work-card-image {
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-bg-subtle);

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--duration-slow) var(--ease-out);
    }
  }

  .work-card-content {
    padding: var(--space-5);
  }

  .work-card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .work-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .work-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .tag {
    padding: var(--space-1) var(--space-3);
    background: var(--color-accent-glow);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-full);
    border: 1px solid rgba(129, 140, 248, 0.2);
  }

  .work-card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    text-decoration: none;
    transition: gap var(--duration-fast) var(--ease-out);

    &:hover {
      gap: var(--space-3);
    }

    svg {
      flex-shrink: 0;
    }
  }

  .work-card-info {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-style: italic;
    margin-top: var(--space-3);
    margin-bottom: 0;
  }
</style>
