---
<div class="icon-wrapper" set:html={iconSvg} />

<style>
  .icon-wrapper {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
    border-radius: 4px;
  }
</style>
