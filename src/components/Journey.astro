---
import site from "../data/site.json";
const {journey} = site;
const sortedYears = Object.keys(journey).sort((a, b) => Number(b) - Number(a));
---
<section id="journey" aria-label="Career journey">
    <h2 data-reveal>The Journey So Far</h2>
    <div class="timeline" data-reveal>
        {sortedYears.map((year) => (
            <div class="timeline-year">
                <div class="timeline-year-label">
                    <span class="year-badge">{year}</span>
                </div>
                <div class="timeline-events">
                    {journey[year].map(item => (
                        <div class="timeline-event">
                            <div class="event-dot"></div>
                            <div class="event-content">
                                <h3 class="event-title">{item.title}</h3>
                                <p class="event-desc">{item.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        ))}
    </div>
</section>
<style lang="scss">
  .timeline {
    position: relative;
    padding-left: var(--space-7);

    &::before {
      content: '';
      position: absolute;
      left: 11px;
      top: var(--space-2);
      bottom: var(--space-2);
      width: 2px;
      background: linear-gradient(
        to bottom,
        var(--color-accent),
        var(--color-border) 30%,
        var(--color-border) 70%,
        transparent
      );
    }
  }

  .timeline-year {
    margin-bottom: var(--space-8);

    &:last-child {
      margin-bottom: 0;
    }
  }

  .timeline-year-label {
    position: relative;
    margin-bottom: var(--space-5);
    margin-left: calc(-1 * var(--space-7));
    padding-left: var(--space-7);
  }

  .year-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-4);
    background: var(--color-accent-glow);
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    border-radius: var(--radius-full);
    border: 1px solid rgba(129, 140, 248, 0.2);
    position: relative;

    &::before {
      content: '';
      position: absolute;
      left: calc(-1 * var(--space-4) - 5px);
      top: 50%;
      transform: translateY(-50%);
      width: 12px;
      height: 12px;
      background: var(--color-accent);
      border-radius: 50%;
      box-shadow: 0 0 0 4px var(--color-bg), 0 0 12px var(--color-accent-glow);
    }
  }

  .timeline-events {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .timeline-event {
    position: relative;
    display: flex;
    gap: var(--space-4);
  }

  .event-dot {
    position: absolute;
    left: calc(-1 * var(--space-7) + 7px);
    top: 8px;
    width: 8px;
    height: 8px;
    background: var(--color-bg);
    border: 2px solid var(--color-text-tertiary);
    border-radius: 50%;
    flex-shrink: 0;
    z-index: 1;
  }

  .event-content {
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    flex: 1;
    transition: border-color var(--duration-normal) var(--ease-out);

    &:hover {
      border-color: var(--color-border-hover);
    }
  }

  .event-title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-1);
  }

  .event-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: 0;
  }

  @media (max-width: 480px) {
    .timeline {
      padding-left: var(--space-6);

      &::before {
        left: 9px;
      }
    }

    .timeline-year-label {
      margin-left: calc(-1 * var(--space-6));
      padding-left: var(--space-6);
    }

    .year-badge::before {
      left: calc(-1 * var(--space-3) - 5px);
    }

    .event-dot {
      left: calc(-1 * var(--space-6) + 5px);
    }

    .event-content {
      padding: var(--space-3) var(--space-4);
    }
  }
</style>
