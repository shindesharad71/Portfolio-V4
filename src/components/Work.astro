---
import WorkItem from './WorkItem.astro';
import site from "../data/site.json";
const {work} = site;
---
<section id="work" aria-label="Projects">
    <h2 data-reveal>Things I'm proud of</h2>
    <div class="work-grid">
        {work.map((item) => (
            <WorkItem item={item} />
        ))}
    </div>
</section>
<style lang="scss">
  .work-grid {
    display: grid;
    gap: var(--space-5);

    @media (min-width: 600px) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
